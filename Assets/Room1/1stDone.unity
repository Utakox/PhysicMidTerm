  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e50ba17086dd0d441b315907b988fb9a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  manager: {fileID: 1823232039}
  lines:
  - Welcome to our facility testing chamber
  - You were selected to be a tester today to test the physics in our world.
  - We will start with basic tests, and the next room will have more advanced tests.
  - Alright, this is our first room. Do you see the three boxes over there?
  - You need to bring the box with the correct mass and place it in the zone we marked.
  - The mass of all three boxes will be shown on the screen and will update in real
    time
  - I can only say that the zone needs a maximum force of 28.
  voices:
  - {fileID: 8300000, guid: 1e034cb5cad108e4f87d29a5cf39fe7e, type: 3}
  - {fileID: 8300000, guid: b154a91a35260c8479c82ee643d5ce61, type: 3}
  - {fileID: 8300000, guid: 98a310869c872914386a6a8998fa89e7, type: 3}
