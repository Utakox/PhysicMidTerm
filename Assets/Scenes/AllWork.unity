  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e50ba17086dd0d441b315907b988fb9a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  manager: {fileID: 1823232039}
  lines:
  - "Oh, uh\u2026 don\u2019t mind the gravity, okay?"
  - "I forgot to turn off the gravity machine, so\u2026"
  - You can turn off the gravity machine from the top of the dome
  - "There will be a red button you can press. After you press it, don\u2019t be
    surprised by the sound, haha. The machine is just adjusting the gravity."
  - "Once you\u2019re done, I want you to help find the broken parts of the aircraft.
    Our engineers will handle the rest."
  - After that, we will open a portal so you can go to the next mission.
  voices:
  - {fileID: 8300000, guid: 78ccdd2f4f5ea4b4bb01c48f7a288056, type: 3}
  - {fileID: 8300000, guid: 95721d38f4c0d76438aa1fa85459a6f9, type: 3}
